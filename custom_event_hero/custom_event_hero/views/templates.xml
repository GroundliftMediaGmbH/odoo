<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="event_custom_header_style" inherit_id="website_event.layout">
        <xpath expr="//div[@id='wrap']" position="inside">
            <t t-if="event and event.x_studio_website_header">
                <style>
                    .o_record_cover_image,
                    .o_record_cover_container,
                    .o_wevent_event_title {
                        background-image: url('/web/image/event.event/<t t-esc="event.id"/>/x_studio_website_header') !important;
                        background-size: cover !important;
                        background-position: center !important;
                    }
                </style>
            </t>
        </xpath>
    </template>

    <template id="event_custom_description" inherit_id="website_event.event_description_full">
        <xpath expr="//*[@t-field='event.description']" position="replace">
            
            <t t-if="event.x_studio_html_field_eventbeschreibung">
                <div t-field="event.x_studio_html_field_eventbeschreibung" itemprop="description" class="oe_structure"/>
            </t>
            
            <t t-else="">
                <div t-field="event.description" itemprop="description" class="oe_structure"/>
            </t>
            
        </xpath>
    </template>
</odoo>